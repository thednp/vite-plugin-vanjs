{
  "name": "vite-plugin-vanjs",
  "version": "0.2.0",
  "author": "thednp",
  "license": "MIT",
  "description": "A mini meta-framework for VanJS powered by Vite",
  "repository": "https://github.com/thednp/vite-plugin-vanjs",
  "homepage": "https://github.com/thednp/vite-plugin-vanjs#README",
  "type": "module",
  "sideEffects": false,
  "types": "./dist/plugin/index.d.mts",
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "vanjs",
    "vite",
    "plugin",
    "router",
    "meta",
    "ssr",
    "ssg",
    "jsx"
  ],
  "exports": {
    ".": "./dist/plugin/index.mjs",
    "./client": "./dist/client/client.mjs",
    "./jsx-dev-runtime": "./dist/jsx-dev-runtime/jsx-dev-runtime.mjs",
    "./jsx-runtime": "./dist/jsx-runtime/jsx-runtime.mjs",
    "./meta": "./dist/meta/meta.mjs",
    "./router": "./dist/router/router.mjs",
    "./router-lazy": "./dist/router/router-lazy.mjs",
    "./router-route": "./dist/router/router-route.mjs",
    "./router-routes": "./dist/router/router-routes.mjs",
    "./server": "./dist/server/server.mjs",
    "./van": "./dist/setup/van.mjs",
    "./van-debug": "./dist/setup/van-debug.mjs",
    "./van-ext": "./dist/setup/van-ext.mjs",
    "./van-ext-ssr": "./dist/setup/van-ext-ssr.mjs",
    "./van-ssr": "./dist/setup/van-ssr.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest --config vitest.config.ts",
    "test-ui": "vitest --config vitest.config.ts --ui=true",
    "prepublishOnly": "pnpm up --latest && pnpm build && pnpm lint && pnpm format",
    "format": "deno fmt src",
    "lint": "pnpm lint:ts && pnpm check:ts",
    "lint:ts": "deno lint src",
    "fix:ts": "deno lint src --fix",
    "check:ts": "tsc -noEmit"
  },
  "peerDependencies": {
    "csstype": "*",
    "mini-van-plate": "*",
    "vanjs-core": "*",
    "vanjs-ext": "*"
  },
  "dependencies": {
    "csstype": "^3.2.3",
    "mini-van-plate": "^0.6.3",
    "vanjs-core": "^1.6.0",
    "vanjs-ext": "^0.6.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/browser": "^4.1.4",
    "@vitest/coverage-istanbul": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "happy-dom": "^20.8.9",
    "tsdown": "^0.21.7",
    "typescript": "6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-strip-comments": "^0.0.10",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=8.6.0"
  }
}
